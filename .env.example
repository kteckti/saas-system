# Database Configuration
DATABASE_URL=mysql://root:root@localhost:3306/smartops

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# OAuth Configuration (Manus)
MANUS_OAUTH_ID=your_manus_oauth_id
MANUS_OAUTH_SECRET=your_manus_oauth_secret
OWNER_OPEN_ID=your_owner_open_id

# Stripe Configuration (Optional for payment processing)
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# AWS S3 Configuration (Optional for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# Email Configuration (Optional for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Application URL
APP_URL=http://localhost:3000
