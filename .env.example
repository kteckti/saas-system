# ============================================================================
# SmartOps SaaS - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Local development with Docker:
DATABASE_URL=postgresql://smartops:SmartOps@2026!@localhost:5432/smartops

# Vercel Postgres / Neon / Supabase (production):
# DATABASE_URL=postgresql://user:password@host:5432/smartops?sslmode=require

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3000

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret for session tokens (min 32 characters, use a random string)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-here

# PostgreSQL password (used in docker-compose)
POSTGRES_PASSWORD=SmartOps@2026!

# ============================================================================
# ADMIN USER (created by seed script)
# ============================================================================
# Email: kteckti@gmail.com
# Password: SmartOps@2026!
# Role: owner (full access)
# OpenID: local_admin_kteckti
OWNER_OPEN_ID=local_admin_kteckti

# ============================================================================
# OAUTH (Manus) - Optional, for OAuth login
# ============================================================================
VITE_APP_ID=your_manus_app_id
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im
OAUTH_SERVER_URL=https://oauth.manus.im

# ============================================================================
# STRIPE - Optional, for payment processing
# ============================================================================
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ============================================================================
# AWS S3 - Optional, for file storage
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# ============================================================================
# EMAIL - Optional, for notifications
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================================================
# APPLICATION URL
# ============================================================================
APP_URL=http://localhost:3000
